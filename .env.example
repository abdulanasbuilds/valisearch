# =============================================================================
# ValiSearch — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in values.
# NEVER commit .env.local — it is already in .gitignore.
#
# Client-side variables (VITE_ prefix) are bundled into the app.
# Server-side variables are only available in edge functions / Lovable Cloud.
# =============================================================================

# ─── CLIENT-SIDE (VITE_ prefix) ──────────────────────────────────────────────

# Supabase / Lovable Cloud
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# API base URL (defaults to VITE_SUPABASE_URL if not set)
VITE_API_BASE_URL=

# Stripe (publishable key — safe for client)
VITE_STRIPE_PUBLIC_KEY=

# App URL
VITE_APP_URL=http://localhost:8080

# ─── SERVER-SIDE (Edge Functions / Lovable Cloud Secrets) ─────────────────────

# 🤖 AI Providers (free-tier first — priority order)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Premium AI (only used when VALISEARCH_ALLOW_PREMIUM_AI=true)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
VALISEARCH_ALLOW_PREMIUM_AI=false

# 🔍 Search / Data APIs
BRAVE_API_KEY=
SERPAPI_API_KEY=

# 🧠 Business Data APIs
CLEARBIT_API_KEY=
CRUNCHBASE_API_KEY=

# 🎨 Branding / Domain APIs
LOGO_DEV_API_KEY=
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# 🗄 Database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 💳 Payments
STRIPE_SECRET_KEY=
