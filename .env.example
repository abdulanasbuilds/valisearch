# =============================================================================
# ValiSearch — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and NEVER committed to version control.
#
# Client-side keys use the VITE_ prefix (bundled by Vite).
# Server-side keys (edge functions) do NOT use the VITE_ prefix.
# =============================================================================

# ─── AI Providers (priority: OpenRouter → Groq → Gemini) ─────────────────────

# OpenRouter — 100+ models, free tier (https://openrouter.ai)
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Groq — Fast Llama inference, free tier (https://console.groq.com)
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.1-8b-instant

# Gemini — Google AI, free tier (https://aistudio.google.com)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# ─── Premium AI (optional, requires VALISEARCH_ALLOW_PREMIUM_AI=true) ────────

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic (https://console.anthropic.com)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

VALISEARCH_ALLOW_PREMIUM_AI=false

# ─── Search & Data APIs ──────────────────────────────────────────────────────

# Brave Search (https://brave.com/search/api/)
BRAVE_API_KEY=

# SerpAPI — Google search (https://serpapi.com)
SERPAPI_API_KEY=

# ─── Business Intelligence ───────────────────────────────────────────────────

# Clearbit (https://clearbit.com)
CLEARBIT_API_KEY=

# Crunchbase (https://data.crunchbase.com)
CRUNCHBASE_API_KEY=

# ─── Branding & Domain APIs ─────────────────────────────────────────────────

# Logo.dev (https://logo.dev)
LOGO_DEV_API_KEY=

# Namecheap (https://www.namecheap.com/support/api/intro/)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=

# GoDaddy (https://developer.godaddy.com)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ─── Database (Supabase) ────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments (Stripe) ──────────────────────────────────────────────────────

VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────

VITE_APP_URL=http://localhost:5000
